{
  "name": "@enhanced-dom/scrollbar",
  "version": "0.3.0",
  "description": "Scrollbar webcomponent",
  "keywords": [],
  "repository": "https://github.com/enhanced-dom/scrollbar.git",
  "license": "MIT",
  "author": "CD9B4A105290E17E0948E021DF4105107C88693C59C0B891CCC08366C51AEA990902A6A156AC87D88A2FC41422A5E1C3C4071F251F19441C4516000EC25F87DF",
  "main": "index.js",
  "scripts": {
    "prebuild": "rimraf dist/*",
    "build": "tsc -p ./tsconfig.json && webpack --config typed-styles.config.cjs",
    "postbuild": "copyfiles LICENSE.md README.md dist && @enhanced-dom-copy-packagejson",
    "package": "cd dist && npm pack",
    "postinstall": "@enhanced-dom-husky",
    "css": "webpack --config typed-styles.config.cjs --watch --mode=none",
    "lint": "eslint --fix --config eslint.config.cjs src demo && stylelint --fix --config stylelint.config.cjs src/**/*.pcss demo/**/*.pcss",
    "test": "jest --config test/jest.config.cjs --runInBand",
    "demo": "webpack serve --config ./demo/webpack.config.cjs",
    "docs": "webpack build --config ./demo/webpack.config.cjs --mode=production"
  },
  "dependencies": {
    "@enhanced-dom/css": "~0.3.1",
    "@enhanced-dom/webcomponent": "~0.4.0",
    "classnames": "^2.5.1",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@enhanced-dom/babel": "~0.2.1",
    "@enhanced-dom/jest": "~0.2.1",
    "@enhanced-dom/lint": "~0.3.0",
    "@enhanced-dom/react": "~0.3.0",
    "@enhanced-dom/webpack": "~0.4.0",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "jest-environment-linkedom": "^29.0.10",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
